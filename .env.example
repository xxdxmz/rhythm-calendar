BILIBILI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/138.0.0.0 Safari/537.36
# 推荐：专用低权限账号的 Cookie 文件。不要填写到本文件，不要提交 Cookie。
BILIBILI_COOKIE_FILE=secrets/bilibili_cookie.txt
# 仅适用于支持安全 Secret 环境变量的托管平台；本地优先使用上面的文件。
# BILIBILI_COOKIE=
RHYTHM_DATABASE_PATH=data/rhythm_calendar.sqlite3
# 匿名抓取间隔，默认一小时；建议不要设置得过低。
ARCAEA_FETCH_INTERVAL_MINUTES=60
# 可选；Windows 会自动发现 Chrome/Edge，容器中需指向 Chromium。
BILIBILI_BROWSER_EXECUTABLE=
BILIBILI_BROWSER_HEADLESS=true
# Netlify 正式域名，例如 https://rhythm-calendar.netlify.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_STATIC_DATA_URL=https://xxdxmz.github.io/rhythm-calendar/data/snapshot.json
